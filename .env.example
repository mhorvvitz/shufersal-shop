# Copy this file to .env and fill in your values. .env is gitignored.

# Your Shufersal online account credentials.
SHUFERSAL_USERNAME=your-username
SHUFERSAL_PASSWORD=your-password

# Where to get a Chrome instance from. Set ONE of the two:

# Option A — local Chrome (default). Absolute path to a local Chrome executable.
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
# macOS:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux:   /usr/bin/google-chrome
CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Option B — hosted/remote headless Chrome. If set, this takes precedence over
# CHROME_PATH: the bot connects to an already-running Chrome instead of launching
# a local one (e.g. a self-hosted browserless/chrome-headless-shell container, or a
# managed browser-as-a-service provider). Get this URL from your provider/host.
# CHROME_WS_ENDPOINT=ws://your-host:9222/devtools/browser/<id>
