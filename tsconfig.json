{
  "compilerOptions": {
    "module": "esnext",
    "target": "es2021",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "shufersal-automation": ["vendor/shufersal-automation/src/index.ts"],
      "~/*": ["vendor/shufersal-automation/src/*"]
    }
  },
  "include": ["scripts/**/*.ts"]
}
